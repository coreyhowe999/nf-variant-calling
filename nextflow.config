/*
 * Top-level Nextflow config.
 *
 * Pipeline-wide defaults, parameter declarations, profiles, and reporting.
 * Per-process resources live in conf/base.config; profile-specific overrides
 * pull conf/test.config etc.
 */

manifest {
    name            = 'nf-variant-calling'
    author          = 'Corey Howe'
    homePage        = 'https://github.com/coreyhowe999/nf-variant-calling'
    description     = 'Germline short-variant calling: BWA-MEM2 + bcftools'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.10.0'
    version         = '0.1.0'
}

params {
    // I/O
    samplesheet = null
    fasta       = null
    outdir      = 'results'

    // Variant calling knobs
    min_mapq      = 20
    min_baseq     = 20
    ploidy        = 2
    skip_markdup  = false

    // Resource caps (overridden by profiles or CLI)
    max_cpus    = 4
    max_memory  = '8.GB'
    max_time    = '4.h'

    // Reporting / publishing
    publish_mode = 'copy'
}

// Default to base config; profiles layer on top.
includeConfig 'conf/base.config'

profiles {
    test {
        includeConfig 'conf/test.config'
    }

    docker {
        docker.enabled       = true
        singularity.enabled  = false
        conda.enabled        = false
        docker.runOptions    = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
    }

    conda {
        conda.enabled        = true
        docker.enabled       = false
        singularity.enabled  = false
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = 'short'
    }
}

// Reporting
timeline { enabled = true ; file = "${params.outdir}/pipeline_info/timeline.html" ; overwrite = true }
report   { enabled = true ; file = "${params.outdir}/pipeline_info/report.html"   ; overwrite = true }
trace    { enabled = true ; file = "${params.outdir}/pipeline_info/trace.txt"     ; overwrite = true }
dag      { enabled = true ; file = "${params.outdir}/pipeline_info/dag.html"      ; overwrite = true }
